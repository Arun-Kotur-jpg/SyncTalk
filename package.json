{
  "name": "synctalk",
  "version": "1.0.0",
  "private": true,
  "description": "SyncTalk MERN Stack Application",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "seed": "npm run seed -w server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
